generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String    @id @default(uuid())
  
  // Recuperação de senha
  recoveryToken     String?   @unique
  recoveryTokenExp  DateTime?

  email           String?   @unique
  phone           String?   @unique
  password        String
  name            String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  isSuperAdmin    Boolean   @default(false)
  isAdmin         Boolean   @default(false) 
  isResident      Boolean   @default(false)
  isDoorman       Boolean   @default(false)
  isReseller      Boolean   @default(false)
  isHouseResident Boolean   @default(false)
  isCondoResident Boolean   @default(false)

  // Morador dependente (criado pelo morador principal)
  isDependent     Boolean   @default(false)
  parentUserId    String?   // ID do morador principal que criou este dependente
  
  propertiesManaged Property[] @relation("PropertyAdmin")
  propertiesDoorman Property[] @relation("PropertyDoorman")
  units             Unit[]     @relation("UnitResidents")
  
  doorbellEnabled   Boolean   @default(true)
  quietModeStart    String?   
  quietModeEnd      String?   
  
  trialEndsAt       DateTime?
  promoActive       Boolean   @default(false)

  // Código único do cliente (gerado pelo master admin ou pelo próprio usuário)
  clientCode        String?   @unique
  // Código da placa pré-configurada (Opção 1: placa entregue pronta)
  plateCode         String?   @unique

  // Mensagens internas entre morador principal e dependentes
  sentFamilyMessages      FamilyMessage[] @relation("FamilyMessageSender")
  receivedFamilyMessages  FamilyMessage[] @relation("FamilyMessageReceiver")
  
  // Assinaturas de Push Notification (um por aparelho)
  pushSubscriptions PushSubscription[]
}

model FamilyMessage {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("FamilyMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User     @relation("FamilyMessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}


model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model Property {
  id              String    @id @default(uuid())
  type            String    @default("house") 
  name            String
  
  adminId         String?
  admin           User?     @relation("PropertyAdmin", fields: [adminId], references: [id])
  
  doormanId       String?
  doorman         User?     @relation("PropertyDoorman", fields: [doormanId], references: [id])
  
  clientName      String?
  clientPhone     String?
  clientDocument  String?
  clientAddress   String?
  companyName     String?
  plan            String    @default("BASIC")

  // ─── Geofence (raio de segurança do visitante) ──────────────────────────
  geofenceEnabled Boolean   @default(false)
  geofenceLat     Float?    // Latitude do imóvel (decimal)
  geofenceLng     Float?    // Longitude do imóvel (decimal)
  geofenceRadius  Int       @default(10) // Raio em metros (padrão: 10m)
  subdomain       String?   @unique
  
  createdAt       DateTime  @default(now())
  nextPaymentAt   DateTime
  
  units           Unit[]
  messages        Message[]
  visitors        Visitor[]
  mailboxMessages MailboxMessage[]
  alerts          UnitAlert[]
  connections     InternalConnection[]
}

model Unit {
  id                  String     @id @default(uuid())
  propertyId          String
  property            Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name                String
  block               String?
  street              String?
  number              String?
  inviteCode          String?    @unique 
  residents           User[]     @relation("UnitResidents")
  visitors            Visitor[]
  mailboxMessages     MailboxMessage[]
  alerts              UnitAlert[]
  sentConnections     InternalConnection[] @relation("SenderConnection")
  receivedConnections InternalConnection[] @relation("ReceiverConnection")
  visitorCodes        VisitorCode[]
}

model Visitor {
  id              String   @id @default(uuid())
  unitId          String
  unit            Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  photo           String?  
  callerName      String   @default("Visitante")
  timestamp       DateTime @default(now())
}

model Message {
  id              String   @id @default(uuid())
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  title           String
  body            String   
  priority        String   @default("normal")
  senderId        String
  createdAt       DateTime @default(now())
}

model MailboxMessage {
  id              String   @id @default(uuid())
  unitId          String
  unit            Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  subject         String
  body            String
  status          String   @default("pending") // "pending" | "read" | "resolved"
  createdAt       DateTime @default(now())
}

model UnitAlert {
  id              String   @id @default(uuid())
  unitId          String
  unit            Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  type            String   @default("alert") // "release" | "message" | "alert" | "package"
  title           String
  description     String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model InternalConnection {
  id              String   @id @default(uuid())
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  senderUnitId    String
  senderUnit      Unit     @relation("SenderConnection", fields: [senderUnitId], references: [id], onDelete: Cascade)
  receiverUnitId  String
  receiverUnit    Unit     @relation("ReceiverConnection", fields: [receiverUnitId], references: [id], onDelete: Cascade)
  status          String   @default("pending") // "pending" | "connected" | "blocked"
  createdAt       DateTime @default(now())
  messages        InternalMessage[]
}

model InternalMessage {
  id              String   @id @default(uuid())
  connectionId    String
  connection      InternalConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  senderUnitId    String
  body            String
  createdAt       DateTime @default(now())
}

model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model VisitorCode {
  id          String   @id @default(uuid())
  code        String   @unique
  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  visitorName String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}
